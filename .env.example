# ─── Supabase ────────────────────────────────────────────────────────────────
# Get these from your Supabase project Settings → API
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ─── AI / OCR ────────────────────────────────────────────────────────────────
# Google AI Studio keys — Gemini 2.5 Flash-Lite free tier.
# Split by purpose so extraction and summary quotas don't compete.
#   EXTRACT key — OCR + classify + structured extraction (lib/extract.ts)
#   EXPLAIN key — prescription + lab-report plain-language summaries
#                 (lib/explain.ts, /api/explain, /api/analyse)
GEMINI_API_KEY_EXTRACT=your_google_ai_studio_key_1
GEMINI_API_KEY_EXPLAIN=your_google_ai_studio_key_2

# ─── Rate limiting ───────────────────────────────────────────────────────────
# Max requests per IP per window across all AI endpoints (default: 200)
# RATE_LIMIT_MAX=200
# Window duration in seconds (default: 3600 = 1 hour)
# RATE_LIMIT_WINDOW=3600

# ─── Early access ────────────────────────────────────────────────────────────
# Maximum number of registered users allowed (default: 150)
# EARLY_ACCESS_LIMIT=150
