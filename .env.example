# ─── Supabase ────────────────────────────────────────────────────────────────
# Get these from your Supabase project Settings → API
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ─── AI / OCR ────────────────────────────────────────────────────────────────
# Used by lib/extract.ts and app/api/ocr/route.ts for prescription/lab extraction.
# Required unless NEXT_PUBLIC_DEV_MODE=true (then a mock response is returned).
OPENROUTER_API_KEY=your_openrouter_api_key

# ─── Local development ──────────────────────────────────────────────────────
# Skips Supabase auth and injects a mock user via lib/supabase/server.ts.
# ONLY honored when NODE_ENV=development. Never set this in production.
DEV_BYPASS_AUTH=false

# Returns mocked OCR data instead of calling OpenRouter — useful when
# OPENROUTER_API_KEY is unset or you don't want to burn quota during UI work.
NEXT_PUBLIC_DEV_MODE=false
